#!/usr/bin/env bash
set -euo pipefail

echo "==> Installing Ruby dependencies..."
bundle install
echo ""

echo "==> Checking for clang..."
if command -v clang &>/dev/null; then
  echo "    clang found: $(clang --version | head -1)"
else
  echo "    WARNING: clang not found. Install LLVM to compile .c files directly."
  echo "    macOS:   xcode-select --install"
  echo "    Ubuntu:  sudo apt install clang"
fi
echo ""

echo "==> Running tests..."
bundle exec rake test
echo ""

echo "==> Setup complete! Usage:"
echo "    ./bin/s4c program.c -o program.s4"
echo "    ./bin/s4c program.ll -o program.s4"
